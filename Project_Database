CREATE DATABASE school_admin;
USE school_admin;

CREATE TABLE student (
    id BIGINT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100),
    parent_name VARCHAR(100),
    address VARCHAR(255),
    student_class VARCHAR(50),
    section VARCHAR(10),
    email VARCHAR(100),
    phone_number VARCHAR(15)
);

CREATE TABLE employee (
    id BIGINT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100),
    username VARCHAR(50) UNIQUE,
    password VARCHAR(100),
    role VARCHAR(20),  -- ADMIN, CLERK, TEACHER, PRINCIPAL
    email VARCHAR(100),
    phone VARCHAR(15)
);

CREATE TABLE attendance (
    id BIGINT PRIMARY KEY AUTO_INCREMENT,
    student_id BIGINT,
    date DATE,
    status VARCHAR(20), -- Present / Absent

    FOREIGN KEY (student_id) REFERENCES student(id)
    ON DELETE CASCADE
);

CREATE TABLE performance (
    id BIGINT PRIMARY KEY AUTO_INCREMENT,
    student_id BIGINT,
    subject VARCHAR(100),
    marks INT,

    FOREIGN KEY (student_id) REFERENCES student(id)
    ON DELETE CASCADE
);

CREATE TABLE fee_payment (
    id BIGINT PRIMARY KEY AUTO_INCREMENT,
    student_id BIGINT,
    amount DOUBLE,
    payment_date DATE,

    FOREIGN KEY (student_id) REFERENCES student(id)
    ON DELETE CASCADE
);

CREATE TABLE syllabus (
    id BIGINT PRIMARY KEY AUTO_INCREMENT,
    class_name VARCHAR(50),
    subject VARCHAR(100),
    syllabus_details TEXT
);

CREATE TABLE class_schedule (
    id BIGINT PRIMARY KEY AUTO_INCREMENT,
    class_name VARCHAR(50),
    subject VARCHAR(100),
    teacher_name VARCHAR(100)
);

